# Atlas URI (prefer default database in URI path; DB_NAME below should match logical app DB)
MONGO_DETAILS=mongodb+srv://<username>:<password>@<cluster-address>.mongodb.net/?retryWrites=true&w=majority&appName=EventThon
DB_NAME=EventThon_Network
# If login/profile calls "hang" then work after ~30s: Mongo is not reachable (VPN, wrong password, IP not whitelisted on Atlas).
# Optional: fail faster (milliseconds)
# MONGO_SERVER_SELECTION_TIMEOUT_MS=8000
# MONGO_CONNECT_TIMEOUT_MS=8000
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
# Optional: powers Post Wizard "AI Enhance" (falls back to local polish if empty)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
ADMIN_OTP=change_me_secure_admin_otp
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://eventthone.com,https://eventthone.com,http://www.eventthone.com,https://www.eventthone.com
# Gmail SMTP (Forgot Password OTP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
